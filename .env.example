# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://taxease:password@localhost:5432/taxease_dev"
DATABASE_URL_UNPOOLED="postgresql://taxease:password@localhost:5432/taxease_dev"

# ─────────────────────────────────────────────
# REDIS (BullMQ + Caching)
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# AUTHENTICATION — NextAuth.js
# ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
MFA_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ─────────────────────────────────────────────
# AWS S3 (File Storage)
# ─────────────────────────────────────────────
AWS_REGION="af-south-1"
AWS_ACCESS_KEY_ID="AKIAxxxxxxxxxxxxxxxxx"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AWS_S3_BUCKET_NAME="taxease-statements-dev"
AWS_S3_REPORTS_BUCKET="taxease-reports-dev"
S3_PRESIGNED_URL_EXPIRY="900"

# ─────────────────────────────────────────────
# PAYMENTS — Paystack
# ─────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
PAYSTACK_WEBHOOK_SECRET="your-paystack-webhook-secret"

# ─────────────────────────────────────────────
# EMAIL — Resend
# ─────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@banklens.ng"


# ─────────────────────────────────────────────
# OCR — Google Gemini API
# ─────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ─────────────────────────────────────────────
# INTERNAL SERVICES
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_URL="http://localhost:3001"
PARSER_SERVICE_URL="http://localhost:8000"
INTERNAL_API_SECRET="generate-with-openssl-rand-hex-32"

# ─────────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────
NODE_ENV="development"
APP_URL="http://localhost:3000"
API_PORT="3001"
PARSER_PORT="8000"
CBN_EXCHANGE_RATE_API_URL="https://www.cbn.gov.ng/rate"
