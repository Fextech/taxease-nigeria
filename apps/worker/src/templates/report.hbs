<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Banklens Self Assessment - {{taxYear}}</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #1f2937;
            margin: 0;
            padding: 40px;
            background-color: #ffffff;
            font-size: 14px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
            border-bottom: 2px solid #f3f4f6;
            padding-bottom: 20px;
        }
        .header-content h1 {
            color: #0f766e;
            margin: 0 0 8px 0;
            font-size: 28px;
        }
        .header-content p {
            margin: 0;
            color: #6b7280;
            font-size: 14px;
        }
        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #0f766e;
        }
        .cards-container {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }
        .card {
            flex: 1;
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 20px;
        }
        .card-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            border-bottom: 1px dashed #e5e7eb;
            padding-bottom: 4px;
        }
        .card-row:last-child {
            margin-bottom: 0;
            border-bottom: none;
            padding-bottom: 0;
        }
        .label {
            color: #6b7280;
            font-size: 13px;
            font-weight: 500;
        }
        .value {
            font-weight: 600;
            color: #111827;
        }
        .highlight {
            color: #0f766e;
        }
        .month-section {
            margin-bottom: 40px;
            page-break-inside: avoid;
        }
        .month-header {
            background-color: #0f766e;
            color: white;
            padding: 12px 16px;
            border-radius: 6px 6px 0 0;
            margin-bottom: 0;
        }
        .month-header h3 {
            margin: 0;
            font-size: 18px;
        }
        .month-summary {
            display: flex;
            background-color: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-top: none;
            padding: 15px;
            gap: 20px;
            margin-bottom: 15px;
            border-radius: 0 0 6px 6px;
        }
        .summary-item {
            flex: 1;
        }
        .summary-label {
            font-size: 11px;
            text-transform: uppercase;
            color: #065f46;
            margin-bottom: 4px;
        }
        .summary-value {
            font-size: 16px;
            font-weight: 700;
            color: #047857;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        th, td {
            text-align: left;
            padding: 10px 12px;
            border-bottom: 1px solid #e5e7eb;
        }
        th {
            background-color: #f9fafb;
            color: #4b5563;
            font-weight: 600;
        }
        .amount-pos {
            color: #059669;
            font-weight: 600;
        }
        .amount-neg {
            color: #dc2626;
            font-weight: 600;
        }
        .footer {
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            color: #9ca3af;
            font-size: 12px;
        }
        .footer a {
            color: #0f766e;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <div class="header">
        <div class="header-content">
            <h1>{{taxYear}} Self Assessment</h1>
            <p>Created with Banklens by Flowiselabs</p>
        </div>
        <div class="logo">
            Banklens
        </div>
    </div>

    <div class="cards-container">
        <!-- Top Card 1 -->
        <div class="card">
            <div class="card-row">
                <span class="label">Name</span>
                <span class="value">{{userName}}</span>
            </div>
            <div class="card-row">
                <span class="label">Professional Category</span>
                <span class="value">{{professionalCategory}}</span>
            </div>
            <div class="card-row">
                <span class="label">TIN</span>
                <span class="value">{{tin}}</span>
            </div>
            <div class="card-row">
                <span class="label">Gross Income</span>
                <span class="value highlight">{{grossIncome}}</span>
            </div>
            <div class="card-row">
                <span class="label">Tax Liability</span>
                <span class="value highlight">{{taxLiability}}</span>
            </div>
        </div>

        <!-- Top Card 2 -->
        <div class="card">
            <div class="card-row">
                <span class="label">Total Inflow</span>
                <span class="value">{{totalInflow}}</span>
            </div>
            <div class="card-row">
                <span class="label">Direct Business Expenses</span>
                <span class="value">{{directBusinessExpenses}}</span>
            </div>
            <div class="card-row">
                <span class="label">Other Expenses</span>
                <span class="value">{{otherExpenses}}</span>
            </div>
            <div class="card-row">
                <span class="label">Taxable Income</span>
                <span class="value highlight">{{taxableIncome}}</span>
            </div>
            <div class="card-row">
                <span class="label">Total Relief</span>
                <span class="value highlight">{{totalRelief}}</span>
            </div>
        </div>
    </div>

    {{#each months}}
    <div class="month-section">
        <div class="month-header">
            <h3>{{this.monthName}}</h3>
        </div>
        <div class="month-summary">
            <div class="summary-item">
                <div class="summary-label">Gross Income</div>
                <div class="summary-value">{{this.grossIncome}}</div>
            </div>
            <div class="summary-item">
                <div class="summary-label">Direct Bus. Exp.</div>
                <div class="summary-value">{{this.directBusinessExpenses}}</div>
            </div>
            <div class="summary-item">
                <div class="summary-label">Other Expenses</div>
                <div class="summary-value">{{this.otherExpenses}}</div>
            </div>
            <div class="summary-item">
                <div class="summary-label">Taxable Income</div>
                <div class="summary-value">{{this.taxableIncome}}</div>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th style="width: 15%">Date</th>
                    <th style="width: 30%">Description</th>
                    <th style="width: 15%">Credit/Debit</th>
                    <th style="width: 10%">Taxable?</th>
                    <th style="width: 30%">Reason / Justification</th>
                </tr>
            </thead>
            <tbody>
                {{#each this.transactions}}
                <tr>
                    <td>{{this.date}}</td>
                    <td>{{this.description}}</td>
                    <td class="{{#if this.isCredit}}amount-pos{{else}}amount-neg{{/if}}">{{this.amount}}</td>
                    <td>{{this.taxable}}</td>
                    <td>{{this.reason}}</td>
                </tr>
                {{/each}}
                {{#unless this.transactions}}
                <tr>
                    <td colspan="5" style="text-align: center; color: #9ca3af; padding: 20px;">No relevant transactions recorded for this month.</td>
                </tr>
                {{/unless}}
            </tbody>
        }
        </table>
    </div>
    {{/each}}

    <div class="footer">
        <div>Generated on {{generatedAt}}</div>
        <div>&copy; {{currentYear}} <a href="#">Banklens</a> All rights reserved.</div>
    </div>

</body>
</html>
